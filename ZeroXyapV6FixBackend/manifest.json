{
  "manifest_version": 3,
  "name": "ZeroXyap",
  "version": "6.0",
  "description": "Generates direct, hyper-realistic, and imperfectly human replies on X.com with selectable AI personas.",
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "*://*.x.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost:11434/*",
    "https://api.novita.ai/*",
    "https://api.ipify.org/*",
    "https://ntliyksisoqoeywuyxbw.supabase.co/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "login.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}